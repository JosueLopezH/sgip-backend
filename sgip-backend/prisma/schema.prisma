generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}
 
datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}
 
// Enum de estados para proyectos y tareas
enum Status {
  PENDING
  STARTED
  IN_PROCESS
  COMPLETED
  CANCELED
}
 
// Enum de roles de usuario en el sistema
enum Role {
  ADMIN
  PM
  DEVELOPER
  ANALYST
  VIEWER
}
 
model User {
  id        String    @id @default(cuid())
  name      String    @db.VarChar(128)
  username  String    @unique @db.VarChar(64)
  email     String    @unique @db.VarChar(128)
  password  String
  role      Role      @default(DEVELOPER)
  active    Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt
 
  // Relaciones: un usuario puede administrar proyectos y tener tareas asignadas
  projects  Project[]
  tasks     Task[]
}
 
model Project {
  id          String    @id @default(cuid())
  name        String    @db.VarChar(128)
  description String?   @db.VarChar(512)
  status      Status    @default(PENDING)
  budget      Decimal?  @db.Decimal(12, 2)
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime? @updatedAt
 
  // Un proyecto tiene un manager (FK a User)
  managerId String
  manager   User   @relation(fields: [managerId], references: [id])
  tasks     Task[]
}
 
model Task {
  id          String    @id @default(cuid())
  name        String    @db.VarChar(128)
  description String?   @db.VarChar(512)
  completed   Boolean   @default(false)
  dueDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime? @updatedAt
 
  // Una tarea pertenece a un proyecto y puede estar asignada a un usuario
  projectId  String
  project    Project @relation(fields: [projectId], references: [id])
  assigneeId String?
  assignee   User?   @relation(fields: [assigneeId], references: [id])
}